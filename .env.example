# Base de données (Docker)
DATABASE_URL=postgresql+psycopg://ats_user:ats_pass@db:5432/ats_db

# IA
ANTHROPIC_API_KEY=

# Auto-apply emploi-territorial.fr
EMPLOI_TERRITORIAL_LOGIN=
EMPLOI_TERRITORIAL_PASSWORD=

# Auto-apply emploi.fhf.fr
EMPLOI_FHF_LOGIN=
EMPLOI_FHF_PASSWORD=

# Fichiers joints (dans le conteneur API)
CV_PATH=/app/config/cv_amadou_mactar_ndiaye.pdf
DIPLOME_PATH=/app/config/diplomes_amadou_mactar.pdf

# Retry auto-apply
AUTO_APPLY_STEP_RETRIES=2
AUTO_APPLY_RETRY_DELAY_S=1.0

# Email expéditeur (utilisé pour l'en-tête From)
SMTP_EMAIL=
SMTP_PASSWORD=

# Gmail API OAuth2
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
